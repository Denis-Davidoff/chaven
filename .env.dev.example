# Ethereum Sepolia (dev)

# --- Required ---

# RPC endpoint (default works, but a private one from Alchemy/Infura is more reliable)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key of the wallet that deploys/mints. Must hold Sepolia ETH.
PRIVATE_KEY=

# Etherscan V2 multichain API key (works for Sepolia and Base both).
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Pinata JWT for IPFS pinning (used by scripts/ipfs.ts).
# Get one at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# --- Optional ---

# Sale price in ETH for newly minted tokens (used by scripts/mint.ts). Default: 0.05
# SALE_PRICE=0.05

# Override the contract address from deployments/dev.json (used by scripts/mint.ts).
# CONTRACT_ADDRESS=

# Override the tokenURI from deployments/dev.json (used by scripts/mint.ts).
# TOKEN_URI=
