{
  "name": "chaven",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "deploy:dev": "HARDHAT_ENV=dev hardhat run scripts/deploy.ts --network sepolia",
    "deploy:prod": "HARDHAT_ENV=prod hardhat run scripts/deploy.ts --network base",
    "ipfs:dev": "HARDHAT_ENV=dev ts-node scripts/ipfs.ts",
    "ipfs:prod": "HARDHAT_ENV=prod ts-node scripts/ipfs.ts",
    "mint:dev": "HARDHAT_ENV=dev hardhat run scripts/mint.ts --network sepolia",
    "mint:prod": "HARDHAT_ENV=prod hardhat run scripts/mint.ts --network base",
    "verify:dev": "HARDHAT_ENV=dev hardhat verify --network sepolia",
    "verify:prod": "HARDHAT_ENV=prod hardhat verify --network base"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  }
}
